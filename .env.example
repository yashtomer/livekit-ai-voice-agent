# LiveKit Server Configuration
# LIVEKIT_URL is the URL the BROWSER uses to connect (returned via token
# server). When running everything via `docker compose up`, keep it as
# ws://localhost:7880 — the livekit-server container port-forwards to it.
# The agent container uses its own LIVEKIT_URL internally (ws://livekit-server:7880)
# which is set directly in docker-compose.yml, not from this file.
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── Local service URLs (native-dev only) ───
# Only needed if you run `src/agent.py` / `uvicorn src.token_server:app`
# directly on your host (not via Docker). Inside Docker these are overridden
# by the `environment:` blocks in docker-compose.yml.
#
# OLLAMA_URL=http://localhost:11434
# VOICEBOX_URL=http://localhost:17493
# TTS_BASE_URL=http://localhost:8200/v1       (agent — Piper TTS endpoint)
# PIPER_URL=http://localhost:8200/v1          (token server — /api/tts-sample)
# WHISPER_TINY_URL=http://localhost:8102/v1
# WHISPER_BASE_URL=http://localhost:8100/v1
# WHISPER_SMALL_URL=http://localhost:8101/v1
# WHISPER_BASE_MULTI_URL=http://localhost:8103/v1
# WHISPER_SMALL_MULTI_URL=http://localhost:8104/v1

# Core stack runs locally — no keys needed:
# - LLM:  Ollama on localhost:11434 (stays on HOST even when rest is dockerized)
# - STT:  Faster-Whisper on localhost:8100-8104
# - TTS:  OpenedAI-Speech (Piper) on :8200  +  Voicebox on :17493

# ─── Optional cloud providers ───
# Set any of these to unlock matching options in the UI dropdowns.
# Install cloud plugins (Anthropic, Deepgram) with: uv sync --extra cloud

# ── LLM providers ──
# OpenAI GPT-4o-mini / GPT-4o — https://platform.openai.com/
# OPENAI_API_KEY=
# Google Gemini 1.5 / 2.0 Flash — https://aistudio.google.com/apikey
# GOOGLE_API_KEY=
# Groq (fastest) — https://console.groq.com/
# GROQ_API_KEY=
# Anthropic Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY=
# DeepSeek Chat — https://platform.deepseek.com/
# DEEPSEEK_API_KEY=

# ── STT providers ──
# Deepgram Nova-3 (best for voice) — https://console.deepgram.com/
# DEEPGRAM_API_KEY=
# (OPENAI_API_KEY above also unlocks OpenAI Whisper-1)

# ── TTS providers ──
# ElevenLabs (gold-standard voice quality) — https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=
# (OPENAI_API_KEY above also unlocks OpenAI TTS-1 / TTS-1-HD)

# Microsoft Azure Neural TTS — the OFFICIAL Microsoft TTS (same voices as the
# free edge-tts dropdown entries, but ~3-5× faster and SLA-backed).
# Sign up free:  https://portal.azure.com/  →  Create a resource  →  "Speech"
#                →  Pricing tier F0 (free, 500K chars/month)
# You get TWO values — copy them in:
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=eastus      # or westeurope, centralindia, japaneast, etc.
#                                 # pick the region closest to your users

# Voicebox (local ElevenLabs alternative with voice cloning) — https://voicebox.sh
# No API key needed. Two paths to run it:
#
#  A) Backend-only (fastest, REST API on 17493):
#       cd voicebox && just dev-backend
#     Then create a preset profile via curl:
#       curl -sX POST http://localhost:17493/profiles \
#         -H 'content-type: application/json' \
#         -d '{"name":"Kokoro Default","language":"en","voice_type":"preset",
#              "preset_engine":"kokoro","default_engine":"kokoro"}'
#     Or run: `uv run python scripts/voicebox_bootstrap.py`
#
#  B) Full desktop app (voice-cloning UI, effects editor, timeline):
#     Requires `brew install bun` + rustup — then: `cd voicebox && just dev`
#
# VOICEBOX_URL=http://localhost:17493
