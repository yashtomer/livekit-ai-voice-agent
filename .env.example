# ════════════════════════════════════════════════════════════════════
# AI Voice Cost Calculator — Environment Variables
# Copy this file to .env and fill in the values.
# ════════════════════════════════════════════════════════════════════

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=voiceagent

# ─── Host port mappings ─────────────────────────────────────────────
# HOST_BIND controls which host interface published ports listen on.
#   127.0.0.1 (default) — loopback only; Apache fronts it for HTTPS.
#   0.0.0.0             — all interfaces; use for LAN/dev access without a proxy.
# Override the host-side port number on a server with conflicts; container
# internals don't move. Whisper/TTS stay on the docker network only.
HOST_BIND=127.0.0.1
BACKEND_PORT=8000
FRONTEND_PORT=3000
VOICEBOX_PORT=17493

# ─── LiveKit URLs ───────────────────────────────────────────────────
# LIVEKIT_URL is the INTERNAL url used by backend/agent inside docker.
# Always ws://livekit:7880 in this stack — leave it alone.
LIVEKIT_URL=ws://livekit:7880

# LIVEKIT_PUBLIC_URL is the WSS endpoint the BROWSER hits.
# In production, Apache/nginx proxies wss://livekit.aeologic.in → livekit:7880.
LIVEKIT_PUBLIC_URL=wss://livekit.aeologic.in

# ─── Frontend bundle (baked into the Vite build at docker-compose build time) ─
# Browser uses this for both HTTP API calls and the wss:// upgrade (Gemini WS).
VITE_BACKEND_URL=https://api-aivoice.aeologic.in

# ─── CORS (comma-separated origins) ─────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Required: LiveKit credentials ──────────────────────────────────
# Must match an entry in livekit.yaml's `keys:` map AND sip.yaml's
# `api_key`/`api_secret`. Change all three together.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── Required: Security ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# Shared secret between backend and the agent worker for the internal
# room-config channel (so per-call API keys never go through the browser).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_AGENT_SECRET=dev-internal-agent-secret-change-in-production

# ─── Admin user (created on first startup) ──────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login

# ─── Optional: Local service URLs ───────────────────────────────────
# Only needed if running natively (not via Docker Compose).
# OLLAMA_URL=http://localhost:11434
# VOICEBOX_URL=http://localhost:17493
# PIPER_URL=http://localhost:8200/v1

# ─── Optional: Cloud provider API keys ──────────────────────────────
# Admin can use these directly; customers configure their own via the UI.

# LLM providers
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# STT providers
# DEEPGRAM_API_KEY=...

# TTS providers
# ELEVENLABS_API_KEY=...
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_REGION=eastus


PHONE_NUMBER_ID=your_phone_number_id
ULTRAVOX_API_KEY=your_ultravox_api_key
META_VERIFY_TOKEN=replace_with_meta_verify_token
ULTRAVOX_PORT=3001
ACCESS_TOKEN=your_access_token
CALL_MODE=normal
WHATSAPP_DISPLAY_NUMBER=your_whatsapp_number

PHONE_LANGUAGE=en
PHONE_SYSTEM_PROMPT=""

# ─── Gemini Live model selection ────────────────────────────────────
# Used by both the browser WS (/api/gemini/ws) and the Vobiz phone bridge.
# Common combos:
#   gemini-2.0-flash-live-001                + v1beta   (stable Live model)
#   gemini-2.0-flash-exp                     + v1alpha  (older experimental)
#   gemini-live-2.5-flash-preview            + v1beta   (newer preview)
#   gemini-2.5-flash-preview-native-audio-dialog + v1alpha (native-audio dialog)
GEMINI_LIVE_MODEL=gemini-2.0-flash-live-001
GEMINI_API_VERSION=v1beta

TWILIO_ACCOUNT_SID=sid
TWILIO_API_KEY=api_key
TWILIO_API_SECRET=api_secret
TWILIO_TWIML_APP_SID=app_sid
TWILIO_PHONE_NUMBER=phone_no

# ─── Vobiz Voice API (inbound calls via Indian number) ──────────────
# Get from console.vobiz.ai → API → Auth.
# Required for OUTBOUND calls only. Inbound (webhook) needs only the
# Answer URL configured in the Vobiz number settings.
VOBIZ_AUTH_ID=
VOBIZ_AUTH_TOKEN=
VOBIZ_PHONE_NUMBER=+91XXXXXXXXXX


TATA_AUTH_TOKEN=your_tata_token
# Inbound/outbound: the agent mobile number (shown on the Inbound Call tab).
TATA_AGENT_NUMBER=agent_number

GOOGLE_CLIENT_ID=client_id
GOOGLE_CLIENT_SECRET=client_secret
GOOGLE_REFRESH_TOKEN=refresh_token


WHATSAPP_PHONE_NUMBER_ID=phone_number_id
WHATSAPP_ACCESS_TOKEN=token
WHATSAPP_META_VERIFY_TOKEN=verify_token
WHATSAPP_BUSINESS_ACCOUNT_ID=account_id
WHATSAPP_PHONE_NUMBER=phone_number

# Sent to the customer when a Tata call drops on a network/model/internal error.
# Must be an APPROVED template in your WhatsApp Manager (free-form text only
# delivers inside Meta's 24h window). Defaults to the always-approved hello_world
# for testing — replace with your real disconnect-notice template name + language.
WHATSAPP_DISCONNECT_TEMPLATE=call_disconnected
WHATSAPP_TEMPLATE_LANG=en

# After this many fully off-topic caller requests (e.g. asking a booking agent to
# order a movie ticket), the agent escalates: warm-transfers to a human on phone
# (Tata), or ends the call on browser. Default 3.
OFF_TOPIC_TRANSFER_THRESHOLD=3