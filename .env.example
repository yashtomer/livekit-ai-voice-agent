# ════════════════════════════════════════════════════════════════════
# AI Voice Cost Calculator — Environment Variables
# Copy this file to .env and fill in the values.
# ════════════════════════════════════════════════════════════════════

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=voiceagent

# ─── Host port mappings ─────────────────────────────────────────────
# Change these when deploying to a server with port conflicts. Internal
# container ports stay the same; only the host-side mapping moves.
BACKEND_PORT=8000
FRONTEND_PORT=3000
TTS_PORT=8200
VOICEBOX_PORT=17493
WHISPER_TINY_PORT=8102
WHISPER_BASE_PORT=8100
WHISPER_SMALL_PORT=8101
WHISPER_BASE_MULTI_PORT=8103
WHISPER_SMALL_MULTI_PORT=8104

# ─── Public URLs the browser sees ───────────────────────────────────
# Set in production when deployed behind a domain. LIVEKIT_PUBLIC_URL is
# what the browser uses to reach LiveKit (Apache proxies WSS to LiveKit's
# 7880). LIVEKIT_URL stays internal and points at the host gateway.
# PUBLIC_BACKEND_URL=https://api.aeologic.in
# LIVEKIT_URL=ws://host.docker.internal:7880
# LIVEKIT_PUBLIC_URL=wss://livekit.aeologic.in

# ─── CORS (comma-separated origins) ─────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Required: LiveKit credentials ──────────────────────────────────
# LiveKit runs as shared infra at ~/infra/livekit/. These must match an
# entry in that livekit.yaml's keys: map. `devkey` is the dev/default key.
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# ─── Required: Security ──────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-generated-fernet-key

# Shared secret between backend and the agent worker for the internal
# room-config channel (so per-call API keys never go through the browser).
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_AGENT_SECRET=dev-internal-agent-secret-change-in-production

# ─── Admin user (created on first startup) ──────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-on-first-login

# ─── Optional: Local service URLs ───────────────────────────────────
# Only needed if running natively (not via Docker Compose).
# OLLAMA_URL=http://localhost:11434
# VOICEBOX_URL=http://localhost:17493
# PIPER_URL=http://localhost:8200/v1

# ─── Optional: Cloud provider API keys ──────────────────────────────
# Admin can use these directly; customers configure their own via the UI.

# LLM providers
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...
# GROQ_API_KEY=gsk_...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# STT providers
# DEEPGRAM_API_KEY=...

# TTS providers
# ELEVENLABS_API_KEY=...
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_REGION=eastus
